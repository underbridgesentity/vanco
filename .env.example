# Guest-list approval emails (Vercel serverless function: api/notify-guest.js)
# Set these in Vercel → Project → Settings → Environment Variables.

# Required to actually send mail. Get a key at https://resend.com
RESEND_API_KEY=

# Optional. Sender shown on the email. Use a verified domain for production,
# e.g. "Vanco <guestlist@yourdomain.com>". Defaults to Resend's test sender.
GUEST_FROM=

# Optional. Reply-to address (e.g. management inbox).
GUEST_REPLY_TO=
